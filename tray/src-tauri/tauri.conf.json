{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DropPost",
  "version": "0.2.0",
  "identifier": "com.droppost.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DropPost",
        "width": 480,
        "height": 620,
        "minWidth": 400,
        "minHeight": 500,
        "resizable": true,
        "visible": false,
        "center": true,
        "decorations": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
