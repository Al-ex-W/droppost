{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for DropPost",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-hide",
    "core:window:allow-show",
    "shell:allow-open",
    "dialog:allow-open",
    "store:allow-load",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save",
    "clipboard-manager:allow-write-text"
  ]
}
